# UNLIM Nanobot — Environment Variables
# Copy to .env and fill in values

# AI Provider — choose one:
# Option A: DeepSeek V3 (recommended, lowest cost, best Italian)
AI_PROVIDER=deepseek
AI_API_KEY=sk-...
AI_MODEL=deepseek-chat
# AI_BASE_URL=  (not needed for DeepSeek)

# Option B: Google Gemini 2.0 Flash
# AI_PROVIDER=google
# AI_API_KEY=AIza...
# AI_MODEL=gemini-2.0-flash

# Option C: OpenAI-compatible (GPT-4o-mini or custom)
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1

# CORS: allowed origins (comma-separated)
CORS_ORIGINS=https://elab-builder.vercel.app,https://www.elabtutor.school,http://localhost:5173

# Port (default 8100)
PORT=8100
